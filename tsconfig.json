{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable", "DOM.AsyncIterable", "WebWorker"],
    "allowJs": true,
    "strict": true,
    "paths": {
      "@lib/*": ["./src/lib/*"],
      "@services/*": ["./src/services/*"]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "public"
  ]
}
